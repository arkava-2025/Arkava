---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import Header from '@components/organisms/Header.astro';
import Footer from '@components/organisms/Footer.astro';
import WhatsappHome from '@/components/atoms/WhatsappHome.astro';
import getGeneralPage from '@/lib/hygraph/queries/getGeneralPage';
import '@styles/global.css';
import '@styles/fonts.css';

const generalInfoArkava = await getGeneralPage();

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  schema?: string;
}

// Imagen OG por defecto — reemplazar con imagen branded 1200x630px en /public/og-image.jpg
// Mientras tanto usa una imagen real del portafolio como fallback
const OG_FALLBACK =
  'https://jbmqxuofkzwe1rde.public.blob.vercel-storage.com/contacto.webp';

const {
  title = 'Arkava | Acabados Arquitectónicos y Remodelación en Medellín',
  description = 'Empresa especializada en acabados arquitectónicos de alto nivel y remodelación integral en Medellín. Enchapes, pintura, estuco, cielo rasos, drywall y carpintería a medida.',
  ogImage = OG_FALLBACK,
  canonicalURL = Astro.url.href,
  schema,
} = Astro.props;

const phone = generalInfoArkava?.whatsapp
  ? `+57${String(generalInfoArkava.whatsapp).replace(/\D/g, '')}`
  : undefined;

const localBusinessSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Arkava',
  description:
    'Empresa especializada en acabados arquitectónicos y remodelación integral en Medellín. Enchapes, pintura, estuco, cielo rasos, drywall y carpintería a medida.',
  url: 'https://arkava.com.co',
  ...(phone && { telephone: phone }),
  ...(generalInfoArkava?.email && { email: generalInfoArkava.email }),
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Medellín',
    addressRegion: 'Antioquia',
    addressCountry: 'CO',
  },
  areaServed: [
    { '@type': 'City', name: 'Medellín' },
    { '@type': 'AdministrativeArea', name: 'Antioquia' },
  ],
  priceRange: '$$',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Servicios de Acabados Arquitectónicos',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Pintura de interiores y exteriores',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Enchapes y revestimientos cerámicos',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Estuco decorativo' },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Muros en Drywall y Superboard',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Muros decorativos y microcemento',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Cielo rasos' },
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Carpintería a medida' },
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Argamasa y revoque' },
      },
    ],
  },
});

const headerInfo = {
  logo: generalInfoArkava?.logo?.url,
  title: generalInfoArkava?.title,
  logoDark: generalInfoArkava?.logoDark?.url,
  instagram: generalInfoArkava?.urlInstagram,
  whatsapp: generalInfoArkava?.whatsapp,
  email: generalInfoArkava?.email,
};
---

<html lang="es-CO">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO primario -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Arkava" />
    <meta name="publisher" content="Arkava" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Arkava" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta
      property="og:image"
      content={ogImage.startsWith('http')
        ? ogImage
        : new URL(ogImage, Astro.site).href}
    />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="es_CO" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content={ogImage.startsWith('http')
        ? ogImage
        : new URL(ogImage, Astro.site).href}
    />

    <!-- Pinterest -->
    <meta name="p:domain_verify" content="29fd07084c729214eeb62b40aab8a34b" />

    <!-- Preload fuentes críticas (evita FOIT/CLS) -->
    <link
      rel="preload"
      href="/fonts/PP-Supply/PPSupplySans-Regular.otf"
      as="font"
      type="font/otf"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/Helvetica/Helvetica.ttf"
      as="font"
      type="font/ttf"
      crossorigin="anonymous"
    />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={localBusinessSchema} />
    {schema && <script type="application/ld+json" set:html={schema} />}
  </head>
  <body class="min-h-dvh bg-white antialiased font-pp-sans">
    <Header headerInfo={headerInfo} />
    <WhatsappHome wtNumber={headerInfo.whatsapp} />
    <Analytics />
    <SpeedInsights />
    <slot />
    <Footer headerInfo={headerInfo} />
  </body>
</html>
