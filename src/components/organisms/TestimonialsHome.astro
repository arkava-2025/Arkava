---
import { getCollection } from 'astro:content';

const props = Astro.props as {
  testimonials?: Awaited<ReturnType<typeof getCollection>>;
  title?: string;
  subtitle?: string;
};

const testimonials =
  ((props.testimonials ??
    (await getCollection('testimonials'))) as unknown as any[]) ?? [];

const testimonialsSorted = [...testimonials]
  .sort(
    (a: any, b: any) =>
      Number(Boolean(b?.data?.featured)) - Number(Boolean(a?.data?.featured)),
  )
  .slice(0, 6);

const reviewSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Arkava',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5',
    bestRating: '5',
    reviewCount: String(testimonialsSorted.length),
  },
  review: testimonialsSorted.map((t: any) => ({
    '@type': 'Review',
    author: { '@type': 'Person', name: t?.data?.name ?? 'Cliente' },
    reviewBody: t?.data?.quote ?? '',
    reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
  })),
});

const getInitials = (name?: string) => {
  const parts = String(name ?? '')
    .trim()
    .split(/\s+/)
    .filter(Boolean);
  const first = parts[0]?.[0] ?? '';
  const last = parts.length > 1 ? (parts[parts.length - 1]?.[0] ?? '') : '';
  return (first + last).toUpperCase();
};
---

<script type="application/ld+json" set:html={reviewSchema} />
<section class="px-6 py-12 md:py-16">
  <div class="mx-auto max-w-[1290px]">
    <div class="text-center">
      <h2 class="font-bold text-3xl lg:text-4xl 2xl:text-5xl">Testimonios</h2>
      <p
        class="mt-4 text-base md:text-lg font-secondary text-primary/85 max-w-3xl mx-auto leading-relaxed"
      >
        Historias reales de clientes que confiaron en Arkava para construir,
        remodelar y transformar sus espacios con calidad, detalle y
        cumplimiento.
      </p>
    </div>

    <div
      class="mt-10 grid gap-5 md:gap-6 grid-cols-1 md:grid-cols-2 xl:grid-cols-3"
    >
      {
        testimonialsSorted.map((t: any) => {
          const fullRole = [t?.data?.role, t?.data?.company]
            .filter(Boolean)
            .join(' · ');

          return (
            <article class="relative overflow-hidden rounded-2xl border border-secondary/10 bg-secondary shadow-[0_10px_30px_rgba(0,0,0,0.35)]">
              <div class="absolute inset-0 bg-gradient-to-b from-secondary/[0.06] via-transparent to-secondary/20" />

              <div class="relative p-6 md:p-7">
                <div class="flex items-start justify-between">
                  <div class="text-[56px] leading-none font-black text-primary/70 select-none">
                    “
                  </div>
                </div>

                <p class="mt-3 text-[15px] md:text-base leading-relaxed text-primary/80 font-helvetica font-[600] italic">
                  {t?.data?.quote}
                </p>

                <div class="mt-6 h-px w-full bg-secondary/10" />

                <div class="mt-5 flex items-center gap-3">
                  <div class="relative h-10 w-10 rounded-full bg-primary/10 ring-1 ring-primary/10 overflow-hidden flex items-center justify-center">
                    {t?.data?.avatarUrl ? (
                      <img
                        src={t?.data?.avatarUrl}
                        alt={`Foto de ${t?.data?.name}`}
                        loading="lazy"
                        class="h-full w-full object-cover"
                        width={40}
                        height={40}
                      />
                    ) : (
                      <span class="text-xs font-semibold text-primary/80">
                        {getInitials(t?.data?.name)}
                      </span>
                    )}
                  </div>

                  <div class="min-w-0">
                    <p class="text-sm font-semibold text-primary truncate">
                      {t?.data?.name}
                    </p>
                    {fullRole ? (
                      <p class="text-xs text-primary/60 truncate">{fullRole}</p>
                    ) : null}
                  </div>
                </div>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
