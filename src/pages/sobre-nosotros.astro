---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TeamCarousel from '@/components/molecules/TeamCarousel.jsx';
import MisionVision from '@/components/organisms/MisionVision.astro';
import OurHistory from '@/components/organisms/OurHistory.astro';

const imgs = [
  'https://res.cloudinary.com/dx9vtev71/image/upload/v1773872440/isa_ypovxq.webp',
  'https://res.cloudinary.com/dx9vtev71/image/upload/v1773872440/santi_rwbdmx.webp',
  'https://res.cloudinary.com/dx9vtev71/image/upload/v1773872440/diego_txhsbx.webp',
  'https://res.cloudinary.com/dx9vtev71/image/upload/v1773872441/alfred_pys569.webp',
  'https://res.cloudinary.com/dx9vtev71/image/upload/v1773875634/cami-disen%CC%83o_gmpj4c.webp',
  'https://res.cloudinary.com/dx9vtev71/image/upload/v1773876348/edgar_l3qsx3.webp',
  'https://res.cloudinary.com/dx9vtev71/image/upload/v1773872440/diego_txhsbx.webp',
  'https://res.cloudinary.com/dx9vtev71/image/upload/v1773872441/alfred_pys569.webp',
  'https://res.cloudinary.com/dx9vtev71/image/upload/v1773875634/cami-disen%CC%83o_gmpj4c.webp',
];
---

<BaseLayout
  title={'Arkava | Quiénes Somos — Empresa de Remodelación en Medellín'}
  description={'Conoce el equipo de Arkava, empresa de acabados arquitectónicos y remodelación en Medellín. Profesionales en enchapes, pintura, estuco, drywall y carpintería con más de 10 años de experiencia.'}
>
  <section>
    <div class="text-center relative top-20 z-10 pb-20">
      <h1
        class="text-4xl md:text-5xl lg:text-6xl font-bold text-primary leading-tight"
      >
        Sobre Nosotros
      </h1>
      <h2 class="text-3xl md:text-4xl font-light text-gray-800 mt-2">
        Acabados arquitectónicos de alto nivel en Medellín
      </h2>
      <p
        class="mt-4 text-lg text-gray-600 max-w-xl mx-auto font-helvetica opacity-75"
      >
        Conócenos mejor y descubre el equipo detrás de <b>Arkava</b>, nuestra
        pasión por la innovación y la excelencia nos impulsa a crear soluciones
        que marquen la diferencia.
      </p>
    </div>

    <div class="w-full overflow-hidden">
      <TeamCarousel images={imgs} client:load />
    </div>

    <div class="relative -top-40 md:-top-24 lg:-top-0 z-10">
      <div class="mx-auto max-w-6xl px-4 md:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div
            class="rounded-2xl bg-white shadow-xl ring-1 ring-black/5 p-6 md:p-7 text-center"
          >
            <div
              class="inline-block rounded-md bg-primary/50 text-primary px-3 py-1 text-sm font-semibold"
            >
              El arte de transformar
            </div>
            <p
              class="mt-3 text-gray-600 text-sm font-helvetica leading-relaxed"
            >
              En <b>ARKAVA</b> creemos que cada espacio cuenta una historia. Por
              eso diseñamos y construimos proyectos que combinan estética, funcionalidad
              y detalle, creando ambientes que se viven y se disfrutan.
            </p>
          </div>
          <div
            class="rounded-2xl bg-white shadow-xl ring-1 ring-black/5 p-6 md:p-7 text-center"
          >
            <div
              class="inline-block rounded-md bg-primary/50 text-primary px-3 py-1 text-sm font-semibold"
            >
              Un equipo que te acompaña
            </div>
            <p
              class="mt-3 text-gray-600 text-sm font-helvetica leading-relaxed"
            >
              Somos un equipo de profesionales en diseño y ejecución de obra que
              trabaja de manera cercana con cada cliente, acompañando cada etapa
              del proyecto con asesoría clara, comunicación constante y atención
              al detalle.
            </p>
          </div>
          <div
            class="rounded-2xl bg-white shadow-xl ring-1 ring-black/5 p-6 md:p-7 text-center"
          >
            <div
              class="inline-block rounded-md bg-primary/50 text-primary px-3 py-1 text-sm font-semibold"
            >
              Compromiso que se cumple
            </div>
            <p
              class="mt-3 text-gray-600 text-sm font-helvetica leading-relaxed"
            >
              Nos comprometemos con la calidad, el cumplimiento de tiempos y la
              correcta ejecución de cada proyecto. Trabajamos con
              responsabilidad para que cada cliente tenga la tranquilidad de
              estar en buenas manos.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div><MisionVision /></div>
  <!-- <div><OurHistory /></div> -->
</BaseLayout>
