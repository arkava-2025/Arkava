---
import ConditionalLayout from '@/layouts/ConditionalLayout.astro';
import Section from '@/components/atoms/Section.astro';
import getServicioByIds from '@/lib/hygraph/queries/getServicioByIds';

const isStandalone = !Astro.props.title;
let { title, description, imageService = [], iconService } = Astro.props;

if (isStandalone) {
  const service = await getServicioByIds('muros-decorativos');
  title = service?.title ?? 'Muros Decorativos';
  description = service?.description;
  imageService = service?.imageService ?? [];
  iconService = service?.iconService;
}

const SEO_DESCRIPTION = 'Muros decorativos con microcemento, venecianos, porcelanato líquido y texturas artesanales en Medellín. Acabados únicos para espacios premium. Arkava.';
const serviceSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description: SEO_DESCRIPTION,
  provider: { '@type': 'LocalBusiness', name: 'Arkava', url: 'https://arkava.com.co' },
  areaServed: 'Medellín, Colombia',
  serviceType: 'Muros decorativos y microcemento',
});

const descriptionText = description?.raw?.children?.map((block: any) =>
  block.children.map((child: any) => child.text),
);
---

<ConditionalLayout
  enabled={isStandalone}
  title={`${title} en Medellín | Acabados Arkava`}
  description={SEO_DESCRIPTION}
  schema={serviceSchema}
>
<Section style="h-auto md:h-[90vh] bg-terracota">
  <div
    class="container mx-auto px-6 lg:px-12 py-0 relative z-10 grid grid-cols-1 md:grid-cols-12 gap-10"
  >
    <!-- ---- TEXTO ---- -->
    <div class="md:col-span-4 flex flex-col justify-start">
      {isStandalone ? (
        <h1 class="text-4xl md:text-6xl font-bold tracking-[0.25em] mb-1 text-white uppercase font-pp-sans">{title}</h1>
      ) : (
        <h2 class="text-4xl md:text-6xl font-bold tracking-[0.25em] mb-1 text-white uppercase font-pp-sans">{title}</h2>
      )}

      <div class="border-l-2 border-white/40 pl-5 mb-6">
        <p
          class="text-white/90 leading-relaxed font-helvetica text-sm md:text-base"
        >
          {descriptionText}
        </p>
      </div>

      <ul
        class="space-y-1 text-white/90 font-bold text-sm md:text-base leading-relaxed"
      >
        <li>• Microcemento</li>
        <li>• Venecianos</li>
        <li>• Porcelanato líquido</li>
        <li>• Corev</li>
        <li>• Graniacril</li>
        <li>• Esgrafiado</li>
        <li>• Imitación de roca</li>
        <li>• Texturas vintage</li>
      </ul>
    </div>

    <!-- ---- CONTENEDOR DE IMÁGENES ---- -->
    <div class="md:col-span-8 relative w-full h-[600px] md:h-[650px]">
      <!-- Imagen fondo derecha -->
      <div
        class="absolute top-0 right-0 w-[80%] md:w-[75%] h-[260px] md:h-[300px] lg:h-[420px] overflow-hidden shadow-xl flex gap-2"
      >
        <img
          src={imageService?.[0]?.url}
          alt={`${title} - microcemento y venecianos Arkava Medellín`}
          class="w-[50%] h-full object-cover"
          loading="lazy"
        />
        <img
          src={imageService?.[3]?.url}
          alt={`Acabado de ${title} artesanal - proyecto Arkava`}
          class="w-[50%] h-full object-cover"
          loading="lazy"
        />
      </div>

      <!-- Imagen textura grande centro -->
      <div
        class="absolute top-44 md:top-48 left-[10%] w-[65%] md:w-[45%] h-[260px] lg:h-[340px] xl:h-[400px] overflow-hidden shadow-xl"
      >
        <img
          src={imageService?.[2]?.url}
          alt={`${title} con porcelanato líquido - Arkava`}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>

      <!-- Imagen inferior marmol -->
      <div
        class="absolute bottom-0 xl:-bottom-16 left-0 w-[60%] md:w-[40%] h-[250px] lg:h-[350px] xl:h-[400px] overflow-hidden shadow-xl"
      >
        <img
          src={imageService?.[1]?.url}
          alt={`${title} imitación mármol - acabado premium Arkava Medellín`}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</Section>
</ConditionalLayout>
