---
import ConditionalLayout from '@/layouts/ConditionalLayout.astro';
import Section from '@/components/atoms/Section.astro';
import getServicioByIds from '@/lib/hygraph/queries/getServicioByIds';

const isStandalone = !Astro.props.title;
let { title, description, imageService, iconService } = Astro.props;

if (isStandalone) {
  const service = await getServicioByIds('estuco');
  title = service?.title ?? 'Estuco';
  description = service?.description;
  imageService = service?.imageService ?? [];
  iconService = service?.iconService;
}

const SEO_DESCRIPTION = 'Aplicación de estuco en interiores y exteriores en Medellín. Acabados lisos, labrados y texturizados para muros y cielos de alta calidad. Arkava.';
const serviceSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description: SEO_DESCRIPTION,
  provider: { '@type': 'LocalBusiness', name: 'Arkava', url: 'https://arkava.com.co' },
  areaServed: 'Medellín, Colombia',
  serviceType: 'Estuco decorativo',
});

const descriptionText = description?.raw?.children?.map((block: any) =>
  block.children?.map((child: any) => child.text),
);
---

<ConditionalLayout
  enabled={isStandalone}
  title={`${title} en Medellín | Acabados Arkava`}
  description={SEO_DESCRIPTION}
  schema={serviceSchema}
>
<Section style="h-auto lg:h-[90vh] bg-[#fff]">
  <!-- CONTENIDO -->
  <div
    class="container relative grid lg:flex grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 px-6 md:px-12 mx-auto h-full"
  >
    <!-- IMAGEN PRINCIPAL GRANDE IZQUIERDA -->
    <div class="lg:col-span-5 w-full h-auto lg:h-full flex">
      <img
        src={imageService && imageService[0]?.url}
        alt={`Aplicación de ${title} en interiores - Arkava Medellín`}
        class="w-full h-[380px] md:h-[520px] lg:h-full object-cover shadow-lg"
        loading="lazy"
      />
    </div>

    <!-- COLUMNA DERECHA (TEXTO + 2 IMÁGENES) -->
    <div class="lg:col-span-7 w-full relative flex flex-col lg:h-full">
      <div class="w-full lg:w-[80%] lg:h-1/2">
        {isStandalone ? (
          <h1 class="text-5xl md:text-6xl font-bold font-pp-sans tracking-[0.65rem] text-gray-900 mb-6 uppercase">{title}</h1>
        ) : (
          <h2 class="text-5xl md:text-6xl font-bold font-pp-sans tracking-[0.65rem] text-gray-900 mb-6 uppercase">{title}</h2>
        )}

        <div class="border-l-2 border-gray-700/60 pl-5 mb-6">
          <p
            class="text-gray-700 text-base md:text-lg leading-relaxed font-helvetica"
          >
            {descriptionText}
          </p>
        </div>
        <!-- IMÁGENES DERECHA -->
      </div>
      <div class="grid-cols-1 gap-6 lg:h-1/2 hidden lg:flex">
        <!-- Imagen superior -->
        <img
          src={imageService && imageService[1]?.url}
          alt={`Detalle de ${title} en pared - acabado premium Arkava`}
          class="w-full h-[260px] md:h-[420px] lg:h-full object-cover flex"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</Section>
</ConditionalLayout>
