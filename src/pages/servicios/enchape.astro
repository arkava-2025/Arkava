---
import ConditionalLayout from '@/layouts/ConditionalLayout.astro';
import Section from '@/components/atoms/Section.astro';
import getServicioByIds from '@/lib/hygraph/queries/getServicioByIds';

const isStandalone = !Astro.props.title;
let { title, description, imageService, iconService } = Astro.props;

if (isStandalone) {
  const service = await getServicioByIds('enchape');
  title = service?.title ?? 'Enchape';
  description = service?.description;
  imageService = service?.imageService ?? [];
  iconService = service?.iconService;
}

const SEO_DESCRIPTION = 'Instalación de enchapes, cerámica y porcelana en pisos y muros en Medellín. Revestimientos para baños, cocinas y fachadas con acabado impecable. Arkava.';
const serviceSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description: SEO_DESCRIPTION,
  provider: { '@type': 'LocalBusiness', name: 'Arkava', url: 'https://arkava.com.co' },
  areaServed: 'Medellín, Colombia',
  serviceType: 'Enchapes y revestimientos',
});

const descriptionText = description?.raw?.children?.map((block: any) =>
  block.children.map((child: any) => child.text),
);
---

<ConditionalLayout
  enabled={isStandalone}
  title={`${title} en Medellín | Acabados Arkava`}
  description={SEO_DESCRIPTION}
  schema={serviceSchema}
>
<Section style="h-auto md:h-[90vh] bg-[#C18778] !py-0">
  <div
    class="container mx-auto flex flex-col px-6 py-8 lg:py-16 md:flex-row gap-6 lg:gap-10 items-start h-full"
  >
    <!-- LEFT COLUMN -->
    <div class="flex flex-col justify-start w-full lg:w-[45%] h-full">
      <!-- TEXT -->
      <div class="h-[45%]">
        {isStandalone ? (
          <h1 class="text-white text-5xl md:text-6xl font-bold tracking-widest mb-8 uppercase">{title}</h1>
        ) : (
          <h2 class="text-white text-5xl md:text-6xl font-bold tracking-widest mb-8 uppercase">{title}</h2>
        )}

        <div class="border-l-2 border-white/50 pl-5 mb-10">
          <p
            class="text-white text-base md:text-lg leading-relaxed font-helvetica xl:w-[75%]"
          >
            {descriptionText}
          </p>
        </div>
      </div>

      <!-- BOTTOM LEFT IMAGE (horizontal) -->
      <div class="w-full h-[360px] md:h-[full] overflow-hidden mt-6">
        <img
          src={imageService?.[1]?.url}
          alt={`Detalle de ${title} en piso - Arkava Medellín`}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
    </div>

    <!-- RIGHT COLUMN IMAGES -->
    <div class="w-full grid grid-cols-1 gap-6 md:w-[55%] h-full">
      <!-- TOP LARGE IMAGE -->
      <div class="w-full h-[360px] md:h-full overflow-hidden">
        <img
          src={imageService?.[0]?.url}
          alt={`Servicio de ${title} profesional - proyecto Arkava`}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</Section>
</ConditionalLayout>
