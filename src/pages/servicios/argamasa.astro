---
import ConditionalLayout from '@/layouts/ConditionalLayout.astro';
import Section from '@/components/atoms/Section.astro';
import getServicioByIds from '@/lib/hygraph/queries/getServicioByIds';

const isStandalone = !Astro.props.title;
let { title, description, imageService, iconService } = Astro.props;

if (isStandalone) {
  const service = await getServicioByIds('argamasa');
  title = service?.title ?? 'Argamasa';
  description = service?.description;
  imageService = service?.imageService ?? [];
  iconService = service?.iconService;
}

const SEO_DESCRIPTION = 'Aplicación de argamasa, mortero y revoque para acabados de muros en Medellín. Nivelación, impermeabilización y bases de alta calidad para construcción y remodelación. Arkava.';
const serviceSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description: SEO_DESCRIPTION,
  provider: { '@type': 'LocalBusiness', name: 'Arkava', url: 'https://arkava.com.co' },
  areaServed: 'Medellín, Colombia',
  serviceType: 'Argamasa y revoque',
});

const src_image_one = imageService?.[0]?.url || '';
const src_image_two = imageService?.[1]?.url || '';

const descriptionText = description?.raw?.children?.map((block: any) =>
  block.children.map((child: any) => child.text),
);
---

<ConditionalLayout
  enabled={isStandalone}
  title={`${title} en Medellín | Acabados Arkava`}
  description={SEO_DESCRIPTION}
  schema={serviceSchema}
>
<Section style="h-auto md:h-[90vh] bg-terracota">
  <div class="container mx-auto px-6 lg:px-12 py-0 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Columna izquierda: texto -->
      <section class="col-span-5">
        {isStandalone ? (
          <h1 class="font-display text-white text-5xl md:text-6xl tracking-widest leading-tight mb-6 uppercase" style="letter-spacing: .65rem;">{title}</h1>
        ) : (
          <h2 class="font-display text-white text-5xl md:text-6xl tracking-widest leading-tight mb-6 uppercase" style="letter-spacing: .65rem;">{title}</h2>
        )}

        <div class="border-l-2 border-white/50 pl-5 mb-10">
          <p
            class="text-white text-base md:text-lg leading-relaxed font-helvetica"
          >
            {descriptionText}
          </p>
        </div>
      </section>

      <!-- Espacio para que las imágenes estén a la derecha -->
      <section class="col-span-7 relative">
        <!-- Imagen grande a la derecha - responsive -->
        <div class="relative w-full flex justify-end">
          <figure
            class="w-full md:w-4/5 lg:w-10/12 xl:w-8/12 transform relative top-0 md:-top-12 lg:top-34 2xl:top-20"
          >
            <img
              src={src_image_two}
              alt={`Aplicación de ${title} en muros - Arkava Medellín`}
              class="img-frame w-full h-[420px] lg:h-[580px] object-cover"
              loading="lazy"
            />
          </figure>
        </div>

        <!-- Imagen pequeña superpuesta (grayscale) -->
        <div
          class="absolute left-4 md:left-0 lg:-left-10 bottom-0 md:bottom-8 lg:bottom-14 w-64 md:w-84 lg:w-100 transform -translate-y-6 md:-translate-y-10 lg:translate-y-40 2xl:translate-y-26"
        >
          <img
            src={src_image_one}
            alt={`${title} y revoque - acabado arquitectónico Arkava`}
            class="w-full h-auto object-cover grayscale filter img-frame border-2 border-white/10"
            loading="lazy"
          />
        </div>
      </section>
    </div>
  </div>
</Section>
</ConditionalLayout>
