---
import getHomePage from '@/lib/hygraph/queries/getHomePage';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ComponentRenderer from '@/components/ComponentRenderer.astro';
import getGeneralPage from '@/lib/hygraph/queries/getGeneralPage';
import {
  isPreview,
  sectionOrder,
  buildOrderedSections,
} from '@/lib/utils/sections/index';

const homeData = await getHomePage(
  'home',
  isPreview() ? 'DRAFT' : 'PUBLISHED',
);
const page = homeData.page;

const general = await getGeneralPage();

const orderedSections = buildOrderedSections(
  page?.sections as any[],
  sectionOrder,
);

const rawHomeTitle = page?.title?.trim();
const defaultHomeTitle =
  'Arkava | Acabados arquitectónicos y remodelación integral en Medellín';
const homeTitle =
  rawHomeTitle && rawHomeTitle.length > 0
    ? rawHomeTitle.toLowerCase().includes('arkava')
      ? rawHomeTitle
      : `Arkava | ${rawHomeTitle}`
    : defaultHomeTitle;

const homeCanonical = Astro.site
  ? new URL('/', Astro.site).href
  : 'https://arkava.com.co/';
---

<BaseLayout
  title={homeTitle}
  description={page?.description ?? 'Empresa especializada en acabados arquitectónicos de alto nivel y remodelación integral en Medellín. Enchapes, pintura, estuco, cielo rasos, drywall y carpintería a medida.'}
  canonicalURL={homeCanonical}
>
  <main class="mb-6">
    {
      orderedSections.map((section: any) => (
        <ComponentRenderer
          data={section.content}
          animate={true}
          useTailwind={true}
          whatsapp={general?.whatsapp}
        />
      ))
    }
  </main>
</BaseLayout>
